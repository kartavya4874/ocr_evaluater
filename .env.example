# =============================================================
# OCR Evaluator - Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# The .env file is gitignored and will NOT be pushed to Git.

# OpenAI API Key (get yours at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE

# Google Cloud service account credentials file path
GOOGLE_CLOUD_CREDENTIALS_PATH=/path/to/your/service-account-key.json

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017

# Redis URL
REDIS_URL=redis://localhost:6379
